msgid "The Web of Dreams"
msgstr "Das Netz der Träume"

msgid "Steps of the Bridge"
msgstr "Stufen der Brücke"

msgid "+1, +1, 0, 0, 0, -1, -1, -1, -2, -2, [skull], [skull], [cultist], [elder_thing], [elder_thing], [auto_fail], [elder_sign]"
msgstr "+1, +1, 0, 0, 0, -1, -1, -1, -2, -2, [skull], [skull], [cultist], [elder_thing], [elder_thing], [auto_fail], [elder_sign]"

msgid "+1, 0, 0, -1, -1, -1, -2, -2, -3, -4, [skull], [skull], [cultist], [elder_thing], [elder_thing], [auto_fail], [elder_sign]"
msgstr "+1, 0, 0, -1, -1, -1, -2, -2, -3, -4, [skull], [skull], [cultist], [elder_thing], [elder_thing], [auto_fail], [elder_sign]"

msgid "0, 0, 0, -1, -1, -2, -2, -3, -3, -4, -5, [skull], [skull], [cultist], [elder_thing], [elder_thing], [auto_fail], [elder_sign]"
msgstr "0, 0, 0, -1, -1, -2, -2, -3, -3, -4, -5, [skull], [skull], [cultist], [elder_thing], [elder_thing], [auto_fail], [elder_sign]"

msgid "0, -1, -1, -2, -2, -3, -3, -4, -4, -5, -6, -8, [skull], [skull], [cultist], [elder_thing], [elder_thing], [auto_fail], [elder_sign]"
msgstr "0, -1, -1, -2, -2, -3, -3, -4, -4, -5, -6, -8, [skull], [skull], [cultist], [elder_thing], [elder_thing], [auto_fail], [elder_sign]"

msgid "It looks like you are playing <i>The Web of Dreams</i> as a 4-part campaign. If there is a separate group playing <i>The Dream-Quest</i>, the app can present you with instructions to send them during each interlude, and wait for their input at appropriate times."
msgstr "Scheinbar soll <i>Das Netz der Träume</i> als 4-teilige Kampagne gespielt werden. Wenn eine separate Gruppe <i>Die Traumsuche</i> spielt, kann die App entsprechende Anweisungen geben, die ihnen während der Zwischenspiele übermittelt werden, und auch auf die entsprechenden Antworten warten."

# whitespace is intentional to not trigger rendering issues!?
msgid "Everyone's a Feminist Until There Is a Spider Around:"
msgstr "Wer hat hier eine Spinnen Phobie? "

msgid "Defeat twenty [[Spider]] enemies. Keep track with tally marks in your Campaign Log. <i>(Note: swarm cards do not count.)</i>"
msgstr "Besiege 20 [[Spinne]]-Gegner. Halte dies mit Zählstrichen im Kampagnenlogbuch fest <i>(Anmerkung: Schwarmkarten zählen nicht mit.)</i>"

msgid "The Carter Method"
msgstr "Die Carter-Methode"

msgid "Let every location get infested, then seal all of them in <i>Waking Nightmare</i>."
msgstr "Lass es zu, dass in <i>Erwachter Albtraum</i> alle Orte „befallen werden“, und versiegle sie dann."

msgid "The Doctor is In"
msgstr "Der Doktor ist da"

msgid "Take Dr. Shivani Maheswaran with you and do not let her take any amount of damage or horror in <i>Waking Nightmare</i>."
msgstr "Nimm Dr. Shivani Maheswaran in <i>Erwachter Albtraum</i> mit und schaffe es, dass sie in dem Szenario keinen Schaden und Horror nimmt."

msgid "Déjà Vu"
msgstr "Déjà-vu"

msgid "Resolve every free triggered ability on every location in <i>A Thousand Shapes of Horror</i> (not counting the Mysterious Stairs during act 2)."
msgstr "Handle jede freie ausgelöste Fähigkeit auf jedem Ort in <i>Tausend Formen des Schreckens</i> ab (die Mysteriösen Stufen in Szene 2 zählen nicht mit)."

msgid "The Casa Loma Maneuver"
msgstr "Das „Casa Loma“-Manöver"

msgid "Escape the endless stairs with The Unnamable at the topmost staircase in <i>A Thousand Shapes of Horror</i>."
msgstr "Schaffe es, in <i>Tausend Formen des Schreckens</i> von den endlosen Stufen zu entfliehen, während sich Das Unnennbare auf der obersten Stufe befindet."

# whitespace is intentional to not trigger rendering issues?!
msgid "I Remember This Place"
msgstr "An diesen Ort kann ich mich erinnern "

msgid "Find a way out of the Underworld in <i>Point of No Return</i>."
msgstr "Finde einen Weg aus der Unterwelt in <i>Kein Zurück mehr</i>."

msgid "Bad Advice"
msgstr "Schlecht beraten"

msgid "Flip over every location at least once in <i>Point of No Return</i>."
msgstr "Drehe in <i>Kein Zurück mehr</i> jeden Ort mindestens ein Mal um."

msgid "March of the Ghouls"
msgstr "Aufmarsch der Ghule"

msgid "Have 4 [[Ghoul]] enemies attached to Richard Upton Pickman in <i>Point of No Return</i>."
msgstr "Schaffe es, an Richard Upton Pickman in <i>Kein Zurück mehr</i> 4 [[Ghul]]-Gegner anzuhängen."

msgid "The Ishimura Flex"
msgstr "Der Ishimura-Modus"

msgid "In a single round, defeat all 4 Legs of Atlach-Nacha in <i>Weaver of the Cosmos</i>."
msgstr "Schaffe es in <i>Weber des Kosmos</i>, in einer einzigen Runde alle 4 Beine von Atlach-Nacha zu besiegen."

msgid "You Spin Me Right 'Round:"
msgstr "You Spin Me Right ’Round"

msgid "Ensure that Atlach-Nacha spins a full 360 degrees in a single phase in <i>Weaver of the Cosmos</i>."
msgstr "Schaffe es in <i>Weber des Kosmos</i>, Atlach-Nacha in einer einzigen Phase um eine vollständige 360-Grad-Drehung zu rotieren."

msgid "Master of Unlocking"
msgstr "Schlüsselmeister"

msgid "Use The Silver Key to cancel a total of at least 10 horror throughout the course of a single scenario."
msgstr "Schaffe es, im Verlauf eines einzigen Szenarios mit Der Silberne Schlüssel mindestens 10 Horror aufzuheben."

msgid "Win <i>The Web of Dreams</i> campaign with at least three Ultimatums active."
msgstr "Gewinne die Kampagne <i>Das Netz der Träume</i> mit mindestens 3 aktiven Ultimaten."

msgid "Underworld Expertise"
msgstr "Unterwelt-Experte"

msgid "Win the <i>The Web of Dreams</i> campaign on Expert difficulty."
msgstr "Gewinne die Kampagne <i>Das Netz der Träume</i> auf dem Schwierigkeitsgrad Experte."
