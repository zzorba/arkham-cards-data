msgstr "Cenário II–A: A Busca por Kadath"

msgid "Scenario II-A"
msgstr "Cenário II-A"

msgid "Locations in The Search for Kadath"
msgstr "Locais em A Busca por Kadath"

msgid "Veiled"
msgstr "Velado"

msgid "Enemies with Swarming and Victory"
msgstr "Inimigos com Enxame e Vitória"

