msgid "Return to The Night of the Zealot"
msgstr "重返狂热之夜"

msgid "The Zealot's Revenge"
msgstr "狂热者的复仇"

msgid "Have Lita Chantler’s [reaction] ability deal the killing blow to the Ghoul Priest."
msgstr "利用丽塔·钱德勒的[reaction]能力对食尸鬼祭司造成致命的一击。"

msgid "I Don't Trust Her"
msgstr "我不信任她"

msgid "When given the option to add Lita Chantler to your deck, refuse to do so."
msgstr "在你可以选择将丽塔·钱德勒加入牌组时，拒绝将其加入。"

msgid "Insurance Doesn’t Cover Ghouls"
msgstr "保险合同上可没写食尸鬼"

msgid "Burn your house to the ground in “The Gathering.”"
msgstr "在“聚集与此”冒险中，烧毁你的房子。"

msgid "…But Do I Have To?"
msgstr "大可不必"

msgid "In “The Midnight Masks,” have each investigator remain in Your House for the first three rounds."
msgstr "在“午夜假面”冒险中，所有调查员前三轮都停留在你的房子。"

msgid "Conspiracy of Silence"
msgstr "寂静阴谋"

msgid "Find and interrogate all six unique cultists in “The Midnight Masks.”"
msgstr "在“午夜假面”冒险中，找到并盘问所有6个独特[[异教徒]]。"

msgid "Tour of Arkham"
msgstr "环游阿卡姆"

msgid "Trigger each of the “once per game” abilities on all of the locations in play in “The Midnight Masks.”"
msgstr "在“午夜假面”冒险中，触发场上所有地点的“每场游戏限制1次”能力。"

msgid "Do You Get It Now?"
msgstr "现在你懂了吗？"

msgid "Trigger the <b>Forced</b> ability on Billy Cooper by defeating the Ghoul Priest at his location."
msgstr "在比利·库珀的所在地点，通过击败食尸鬼祭司触发其<b>强制</b>能力。"

msgid "Pinch Hitter"
msgstr "代打"

msgid "Defeat three [[Ghoul]] enemies with a Baseball Bat without it breaking."
msgstr "用一根球棒击败3个[[食尸鬼]]敌人，且球棒没有折断。"

msgid "Even Death May Die"
msgstr "死亡亦逝"

msgid "Defeat Umôrdhoth while the Vault of Earthly Demise is attached to it."
msgstr "击败叠加有尘世墓穴的乌默尔多斯。"

msgid "Break the Circle"
msgstr "打破循环"

msgid "Complete “The Devourer Below” without Umôrdhoth spawning."
msgstr "在乌默尔多斯没有生成的情况下完成“地底噬魔”冒险。"

msgid "They’re Just Misunderstood"
msgstr "迷途羔羊"

msgid "Win the <i>Night of the Zealot</i> campaign without defeating a single unique [[Cultist]] enemy."
msgstr "在没有击败任何独特[[异教徒]]敌人的情况下赢得<i>狂热之夜</i>剧本的胜利。"

msgid "Umôrdhoth’s Favor"
msgstr "乌默尔多斯的青睐"

msgid "Win the <i>Night of the Zealot</i> campaign without defeating a single [[Ghoul]] enemy."
msgstr "在没有击败任何[[食尸鬼]]敌人的情况下赢得<i>狂热之夜</i>剧本的胜利。"

msgid " Win the <i>Night of the Zealot</i> campaign with at least three Ultimatums active."
msgstr "在挑战至少3项究极试炼的情况下获得<i>狂热之夜</i>剧本的胜利。"

msgid "Arkham Expertise"
msgstr "阿卡姆专家"

msgid "Win the <i>Night of the Zealot</i> campaign on Expert difficulty."
msgstr "在专家难度下获得《狂热之夜》剧本的胜利。"
