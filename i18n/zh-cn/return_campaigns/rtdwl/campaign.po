msgid "What Is This Stuff, Anyway?"
msgstr "这究竟是什么东西？"

msgid "Defeat The Experiment using the Alchemical Concoction in “Extracurricular Activities”."
msgstr "在“课外活动”冒险中，用炼金试剂击败实验体。"

msgid "No Void For You"
msgstr "没有你的安身之所"

msgid "Complete “The Miskatonic Museum” without ever defeating the Hunting Horror."
msgstr "在从未击败追猎恐魔的情况下完成“博物馆之夜”冒险。"

msgid "First Rule of Arkham"
msgstr "阿卡姆的第一条规则"

msgid "Burn The Necronomicon in “The Miskatonic Museum.”"
msgstr "在“博物馆之夜”冒险中，烧毁《死灵之书》。"

msgid "All Aboard"
msgstr "全部上车"

msgid "Complete “The Essex County Express” without letting any Helpless Passengers leave play."
msgstr "在没有任何一个无助的旅客离场的情况下完成“疯狂列车”冒险。"

msgid "The Gang’s All Here"
msgstr "大团圆"

msgid "In “The Survivors,” the following characters <i>survived The Dunwich Legacy</i>:"
msgstr "在“幸存者”幕间故事中，以下角色<i>在敦威治事件中存活</i>："

msgid "Dr. Henry Armitage"
msgstr "亨利·阿米蒂奇博士"

msgid "Dr. Francis Morgan"
msgstr "佛朗西斯·摩尔根博士"

msgid "Professor Warren Rice"
msgstr "沃伦·莱斯教授"

msgid "Zebulon Whateley"
msgstr "西布伦·沃特雷"

msgid "Earl Sawyer"
msgstr "厄尔·索耶"

msgid "No Brood Left Behind"
msgstr "断子绝孙"

msgid "Have no Broods of Yog-Sothoth escape into the wild in “Undimensioned and Unseen.”"
msgstr "在“无人知晓”冒险中，没有任何一个犹格·索托斯之子逃跑。"

msgid "Remind Me Not To Piss Her Off"
msgstr "别惹她生气"

msgid "Defeat either version of Seth Bishop while Naomi O’Bannion is under your control."
msgstr "在你控制娜奥米·欧巴尼恩的情况下，击败任意版本的赛斯·毕晓普。"

msgid "Eureka!"
msgstr "我找到了！"

msgid "Identify the Strange Solution."
msgstr "鉴定奇怪的溶液。"

msgid "Beyond What Veil?"
msgstr "是何幻象？"

msgid "Take 10 damage from Beyond the Veil without being defeated."
msgstr "受到转生幻象造成的10点伤害，且没有被击败。"

msgid "Here We Go Again"
msgstr "重新出发"

msgid "Have Dr. Henry Armitage, Dr. Francis Morgan, and Professor Warren Rice in play at the same time."
msgstr "亨利·阿米蒂奇博士、佛朗西斯·摩尔根博士和沃伦·莱斯教授同时在场上。"

msgid "Bird Hunting"
msgstr "鸟类捕猎"

msgid "Defeat 3 Whippoorwills in a single turn."
msgstr "在一个回合中击败3个夜鹰。"

msgid "They Aren’t Getting Away With This"
msgstr "我绝不放过他们"

msgid "Win <i>The Dunwich Legacy</i> campaign as “Ashcan” Pete with Duke listed under “Sacrificed to Yog-Sothoth.”"
msgstr "“灰堆”皮特作为调查员获得《敦威治遗产》剧本的胜利，并且“犹格·索托斯的祭品”下方列有“杜克”。"

msgid "Tabula Rasa"
msgstr "白板说"

msgid "Win The Dunwich Legacy campaign with no [tablet] or [elder_thing] tokens in the chaos bag."
msgstr "获得《敦威治遗产》剧本的胜利，并且混乱袋里没有[tablet]标记，也没有[elder_thing]标记。"

msgid "Line in the Sand"
msgstr "划清界线"

msgid "Win <i>The Dunwich Legacy</i> campaign with at least three Ultimatums active."
msgstr "在挑战至少3项究极试炼的情况下赢得《敦威治遗产》剧本的胜利。"

msgid "Dunwich Expertise"
msgstr "敦威治专家"

msgid "Win <i>The Dunwich Legacy</i> campaign on Expert difficulty."
msgstr "在专家难度下获得《敦威治遗产》剧本的胜利。"
