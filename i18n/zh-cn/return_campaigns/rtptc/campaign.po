msgid "Fair Warning"
msgstr "郑重警告"

msgid "Defeat the Royal Emissary three times during a single playthrough of “Curtain Call.”"
msgstr "在单次“谢幕”冒险期间击败皇家密使三次。"

msgid "First Steps"
msgstr "第一步"

msgid "Interview the following VIPs in “The Last King”:"
msgstr "在“最后的王者”中与如下贵宾会谈："

msgid "Constance Dumaine"
msgstr "康斯坦丝·杜梅因"

msgid "Jordan Perry"
msgstr "乔丹·佩里"

msgid "Ishimaru Haruko"
msgstr "石丸春子"

msgid "Sebastien Moreau"
msgstr "赛巴斯蒂安·莫罗"

msgid "Ashleigh Clarke"
msgstr "阿什莉·克拉克"

msgid "Crashing the Party"
msgstr "摧毁宴会"

msgid "Defeat the [[Lunatic]] version of Dianne Devine in “The Last King.”"
msgstr "在“最后的王者”中击败黛安娜·迪瓦恩的[[狂人]]版本。"

msgid "For Prying Eyes"
msgstr "窥探之眼"

msgid "Add the Hidden Library to the victory display in “Echoes of the Past.”"
msgstr "在“往事回声”中将隐藏的图书馆加入胜利牌区。"

msgid "The Cuckoo's Nest"
msgstr "飞越疯人院"

msgid "Resign with Daniel Chesterfield under an investigator’s control in “The Unspeakable Oath.”"
msgstr "在“邪秽誓约”中，控制著丹尼尔·契斯特菲尔德的调查员撤退。"

msgid "Take A Look At This!"
msgstr "看看这个！"

msgid "Parley with the Host of Insanity in “The Unspeakable Oath.”"
msgstr "在“邪秽誓约”中，与疯狂之主谈判。"

msgid "The Path of Death"
msgstr "死亡之路"

msgid "Use your Clasp of Black Onyx to find a shortcut in “The Pallid Mask.”"
msgstr "在“苍白面具”中，使用你的黑玛瑙扣环来找到捷径。"

msgid "Guessing Game"
msgstr "猜谜游戏"

msgid "Advance to the final agenda of one agenda deck before advacing the first agenda of the other agenda deck in “Black Stars Rise.”"
msgstr "在“黑星升起”中，在一个密谋牌堆的第一个密谋推进前，先将另一个密谋牌堆推进至最后一个密谋。"

msgid "Hastur Made Me Do It"
msgstr "是哈斯塔让我这么干的"

msgid "Defeat Hastur in “Dim Carcosa” while a Possession treachery is in your hand."
msgstr "在“卡城幽影”中，你手中有恶灵附身诡计时击败哈斯塔。"

msgid "Say My Name"
msgstr "吟诵吾名"

msgid "After you have <i>heeded Daniel’s warning</i>, speak the name of HASTUR aloud seven or more times during a single scenario (or its setup)."
msgstr "在你<i>听从丹尼尔的警告</i>后，在单次冒险(或其冒险设置)中说出哈斯塔的名字至少七次。"

msgid "Get Back Here"
msgstr "给我回来"

msgid "Win <i>The Path to Carcosa</i> campaign having never ended a scenario with The Man in the Pallid Mask in play"
msgstr "获得《卡尔克萨之路》剧本的胜利，且每场冒险结束时场上都没有苍白面具下的男子。"

msgid "The Path is False"
msgstr "错误之路"

msgid "Win <i>The Path to Carcosa</i> campaign with <b>8 Doubt</b>."
msgstr "有8点<b>疑惑</b>的情况下获得《卡尔克萨之路》剧本的胜利。"

msgid "The Path is Real"
msgstr "正确之路"

msgid "Win <i>The Path to Carcosa</i> campaign with <b>8 Conviction</b>."
msgstr "有8点<b>确信</b>的情况下获得《卡尔克萨之路》剧本的胜利。"

msgid "Win <i>The Path to Carcosa</i> campaign with less than <b>2 Doubt</b> and <b>Conviction</b> in total."
msgstr "<b>疑惑</b>与<b>确信</b>数合计少于2点的情况下获得《卡尔克萨之路》剧本的胜利。"

msgid "Win <i>The Path to Carcosa</i> campaign with at least three Ultimatums active."
msgstr "在挑战至少3项究极试炼的情况下获得《卡尔克萨之路》剧本的胜利。"

msgid "Carcosa Expertise"
msgstr "卡尔克萨专家"

msgid "Win <i>The Path to Carcosa</i> campaign on Expert difficulty."
msgstr "在专家难度下获得《卡尔克萨之路》剧本的胜利。"
