msgid "Locations"
msgstr "Địa điểm"

msgid ""
"“Through the fevered town had crept a curse which some said was greater than the plague, and which some whispered was the embodied daemon-soul of the plague itself.”\n"
"<right> - HP Lovecraft, <i>The Plague-Daemon</i>.</right>\n"
"“Sometimes, dead is better.”\n"
"<right> - Stephen King, <i>Pet Sematary</i>.</right>"
msgstr ""
"“Một lời nguyền đã len lỏi khắp thị trấn đang chìm trong cơn sốt, thứ mà vài người cho là còn tồi tệ hơn cả bệnh dịch, và vài kẻ khác thì thầm rằng đó chính là hiện thân linh hồn ác quỷ của chính căn bệnh này.”\r\n"
"<right> - HP Lovecraft, <i>The Plague-Daemon</i>.</right>\r\n"
"“Đôi khi, chết lại tốt hơn.”\r\n"
"<right> - Stephen King, <i>Pet Sematary</i>.</right>"

msgid "<i>Call of the Plaguebearer</i> is a campaign for <i>Arkham Horror: The Card Game</i> for 1–4 players"
msgstr "<i>Call of the Plaguebearer</i> là một chiến dịch dành cho <i>Arkham Horror: The Card Game</i> cho 1–4 người chơi"

msgid "<i>I want to live</i>"
msgstr "<i>Tôi muốn sống</i>"

msgid "<i>I'm ready to fight for my life</i>"
msgstr "<i>Tôi đã sẵn sàng chiến đấu vì mạng sống của mình</i>"

msgid "<i>Death doesn't scare me</i>"
msgstr "<i>Cái chết không khiến tôi sợ hãi</i>"
