msgstr "#name# đã đáp lại tiếng gọi."

msgid "In your Campaign Log, record <i>Rallied</i> under the name of each location you have \"rallied\"."
msgstr "Trong Nhật ký Chiến dịch, ghi lại <i>Rallied</i> dưới tên của mỗi địa điểm bạn đã \"rallied\"."

msgid "\"Rallied\""
msgstr "\"Rallied\""

msgid "Rallied"
msgstr "Đã tập hợp"

msgid "In your Campaign Log, record the name of each [[Elite]] enemy in the victory display as <i>Eliminated</i>"
msgstr "Trong Nhật ký Chiến dịch, ghi lại tên của mỗi kẻ địch [[Elite]] trong victory display là <i>Đã bị tiêu diệt</i>"

