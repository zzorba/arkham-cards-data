msgid "The Drowned City"
msgstr "The Drowned City"

msgid "Alien Glyphs"
msgstr "Ký tự Ngoại lai"

msgid "Task progress"
msgstr "Tiến độ nhiệm vụ"

msgid "Artifacts Earned"
msgstr "Cổ vật đã thu thập"

msgid "Locations of R'lyeh"
msgstr "Các địa điểm của R'lyeh"

msgid "Flooded Neighborhoods"
msgstr "Các khu phố bị ngập lụt"

msgid "Artifacts"
msgstr "Cổ vật"

msgid "Relentless"
msgstr "Không khoan nhượng"

msgid "Seal"
msgstr "Niêm phong"

msgid ""
"“... the nightmare corpse-city of R’lyeh, that was built in measureless aeons behind history by the vast, loathsome shapes that seeped down from the dark stars. There lay great Cthulhu and his hordes, hidden in green slimy vaults and sending out at last, after cycles incalculable, the thoughts that spread fear to the dreams of the sensitive and called imperiously to the faithful to come on a pilgrimage of liberation and restoration.”\n"
"<right>–H. P. Lovecraft, “The Call of Cthulhu“</right>"
msgstr ""
"“... thành phố tử thi ác mộng R’lyeh, được xây dựng từ những kỷ nguyên vô tận trước lịch sử bởi những hình thù khổng lồ, gớm ghiếc rỉ xuống từ những vì sao tăm tối. Nơi đó Cthulhu vĩ đại cùng bầy lũ của hắn đang nằm đó, ẩn náu trong những hầm ngục xanh rì nhớp nháp và cuối cùng, sau những chu kỳ không thể đong đếm, phát ra những ý nghĩ gieo rắc nỗi sợ hãi vào giấc mơ của những tâm hồn nhạy cảm và uy quyền kêu gọi những kẻ trung thành bắt đầu một cuộc hành hương của sự giải phóng và phục hồi.”\r\n"
"<right>–H. P. Lovecraft, “The Call of Cthulhu“</right>"

msgid "<i>I want to drift</i>"
msgstr "<i>Tôi muốn trôi dạt</i>"

msgid "<i>I want to dream</i>"
msgstr "<i>Tôi muốn mơ</i>"

msgid "<i>I want to dive</i>"
msgstr "<i>Tôi muốn lặn</i>"

msgid "<i>I want R'lyeh</i>"
msgstr "<i>Tôi muốn R'lyeh</i>"

msgid "One First Last Job"
msgstr "Một Phi Vụ Cuối Cùng Đầu Tiên"

msgid "Complete <i>The Drowned City</i> campaign once on any difficulty."
msgstr ""
"Hoàn thành chiến dịch <i>The Drowned City</i> một lần ở bất kỳ độ khó nào."

msgid "Season Two"
msgstr "Mùa Hai"

msgid ""
"Play through the campaign on hard or expert mode using 4 investigators from "
"4 different previous campaigns."
msgstr ""
"Chơi hết chiến dịch ở chế độ Hard hoặc Expert sử dụng 4 điều tra viên từ 4 "
"chiến dịch khác nhau trước đó."

msgid "Cliff Diver"
msgstr "Nhảy Vách Đá"

msgid "Complete the campaign without ever bringing a diving suit along."
msgstr "Hoàn thành chiến dịch mà không bao giờ mang theo một diving suit."

msgid "This is a Coup"
msgstr "Đây Là Một Cuộc Đảo Chính"

msgid ""
"Defeat both Naomi O’Bannion and Sadie Sheldon in <i>One Last Job</i> using "
"only the act 3a parley ability."
msgstr ""
"Đánh bại cả Naomi O’Bannion và Sadie Sheldon trong <i>One Last Job</i> chỉ "
"bằng cách sử dụng khả năng parley của act 3a."

msgid "Thorough Search"
msgstr "Tìm Kiếm Kỹ Lưỡng"

msgid "End <i>The Western Wall</i> with every location revealed."
msgstr "Kết thúc <i>The Western Wall</i> với mọi địa điểm đã được lật mở."

msgid "Tidal Flip Minigame"
msgstr "Minigame Tidal Flip"

msgid ""
"Complete <i>The Drowned Quarter</i> with each location revealed and not "
"flooded."
msgstr ""
"Hoàn thành <i>The Drowned Quarter</i> với mọi địa điểm đã được lật mở và "
"không bị flooded."

msgid "No Acolyte Left Behind"
msgstr "Không Một Acolyte Nào Bị Bỏ Lại"

msgid "Rescue 5 cultists in <i>The Apiary</i>."
msgstr "Giải cứu 5 cultist trong <i>The Apiary</i>."

msgid "Kill the Adds"
msgstr "Tiêu Diệt Quái Phụ"

msgid ""
"Defeat Mother in <i>The Apiary</i> using only her <b>Forced</b> effect."
msgstr ""
"Đánh bại Mother trong <i>The Apiary</i> chỉ bằng hiệu ứng <b>Forced</b> của "
"bà ta."

msgid "In The Deep End"
msgstr "Ở Vùng Nước Sâu"

msgid ""
"Escape <i>The Grand Vault</i> with the Tidal Tablet after every location has"
" been fully flooded."
msgstr ""
"Trốn thoát khỏi <i>The Grand Vault</i> cùng với Tidal Tablet sau khi mọi địa"
" điểm đã bị ngập hoàn toàn."

msgid "Sorry, Didn’t See You There"
msgstr "Xin Lỗi, Không Thấy Bạn Ở Đó"

msgid ""
"Beat <i>Court of the Ancients</i> without moving the Great Lift after the "
"Colossal Tyrant spawns."
msgstr ""
"Hoàn thành <i>Court of the Ancients</i> mà không di chuyển Great Lift sau "
"khi Colossal Tyrant xuất hiện."

msgid "Sky Rider"
msgstr "Kỵ Sĩ Bầu Trời"

msgid ""
"End your turn in open sky at least 5 times during a single game of "
"<i>Obsidian Canyons</i>."
msgstr ""
"Kết thúc lượt của bạn tại open sky ít nhất 5 lần trong một ván chơi "
"<i>Obsidian Canyons</i>."

msgid "Skip to the End"
msgstr "Đi Thẳng Đến Cuối"

msgid "Defeat Cthulhu in <i>Sepulchre of the Sleeper</i>."
msgstr "Đánh bại Cthulhu trong <i>Sepulchre of the Sleeper</i>."

msgid "Alien School Dropout"
msgstr "Bỏ Học Trường Ngoại Lai"

msgid "Complete the campaign without translating a single alien glyph."
msgstr "Hoàn thành chiến dịch mà không dịch bất kỳ một ký tự ngoại lai nào."

msgid "Alien School Graduate"
msgstr "Tốt Nghiệp Trường Ngoại Lai"

msgid ""
"Translate all 26 alien glyphs during a single playthrough of <i>The Drowned "
"City</i> campaign."
msgstr ""
"Dịch toàn bộ 26 ký tự ngoại lai trong một lần chơi duy nhất của chiến dịch "
"<i>The Drowned City</i>."

msgid "Empty Handed"
msgstr "Trắng Tay"

msgid ""
"Return from R'lyeh without having collected any [[Artifact]] story assets."
msgstr ""
"Trở về từ R'lyeh mà không thu thập bất kỳ story asset [[Artifact]] nào."

msgid "WHY. WON’T. YOU. STAY. DEAD?!"
msgstr "TẠI. SAO. NGƯƠI. KHÔNG. CHỊU. CHẾT?!"

msgid ""
"Add The Inescapable to the victory display at least 20 times during a single"
" campaign."
msgstr ""
"Thêm The Inescapable vào victory display ít nhất 20 lần trong một chiến dịch"
" duy nhất."

msgid "With Your Powers Combined…"
msgstr "Khi Sức Mạnh Được Kết Hợp…"

msgid ""
"Finish <i>The Drowned City</i> campaign having earned the following "
"artifacts:"
msgstr ""
"Hoàn thành chiến dịch <i>The Drowned City</i> sau khi đã kiếm được các "
"artifact sau:"

msgid "Grisly \"Mask\""
msgstr "\"Mặt Nạ\" Rùng Rợn"

msgid "Obligations"
msgstr "Nghĩa vụ"

msgid ""
"Finish <i>The Drowned City</i> campaign with the following tasks completed:"
msgstr ""
"Hoàn thành chiến dịch <i>The Drowned City</i> với các nhiệm vụ sau được hoàn"
" tất:"

msgid ""
"Win <i>The Drowned City</i> campaign with at least three Ultimatums active."
msgstr ""
"Chiến thắng chiến dịch <i>The Drowned City</i> với ít nhất ba Ultimatum đang"
" kích hoạt."

msgid "R’lyeh Expertise"
msgstr "Am Hiểu R’lyeh"

msgid "Win <i>The Drowned City</i> campaign on Expert difficulty."
msgstr "Chiến thắng chiến dịch <i>The Drowned City</i> ở độ khó Expert."
