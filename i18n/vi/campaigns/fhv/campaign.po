msgid "Against Nature"
msgstr "Trái Với Tự Nhiên"

msgid ""
"“It was just a colour out of space—a frightful messenger from unformed realms of infinity beyond all Nature as we know it; from realms whose mere existence stuns the brain and numbs us with the black extra-cosmic gulfs it throws open before our frenzied eyes.”\n"
"<i>– H. P. Lovecraft, “The Colour Out of Space”</i>"
msgstr ""
"“Đó chỉ là một màu sắc đến từ không gian—một sứ giả đáng sợ từ những cõi vô tận chưa thành hình vượt ra ngoài mọi Tự nhiên mà chúng ta biết; từ những cõi mà sự tồn tại đơn thuần của nó làm choáng váng não bộ và làm chúng ta tê liệt với những vực thẳm đen tối ngoài vũ trụ mà nó mở ra trước đôi mắt điên cuồng của chúng ta.”\n"
"<i>– H. P. Lovecraft, “The Colour Out of Space”</i>"

msgid "<i>I want to dance!</i>"
msgstr "<i>Tôi muốn khiêu vũ!</i>"

msgid "<i>I want to feast!</i>"
msgstr "<i>Tôi muốn dự tiệc!</i>"

msgid "<i>I want to be transfigured!</i>"
msgstr "<i>Tôi muốn được biến đổi!</i>"

msgid "<i>I want the Abyss!</i>"
msgstr "<i>Tôi muốn Vực thẳm!</i>"

msgid "Day 1 ([day])"
msgstr "Ngày 1 ([day])"

msgid "Aperitif"
msgstr "Khai vị"

msgid "Complete <i>The Feast of Hemlock Vale</i> campaign once on any difficulty."
msgstr "Hoàn thành chiến dịch <i>The Feast of Hemlock Vale</i> một lần ở bất kỳ độ khó nào."

msgid "Unshattered"
msgstr "Không vỡ vụn"

msgid "Achieve every ending in this campaign."
msgstr "Đạt được mọi kết thúc trong chiến dịch này."

msgid "A Strong, Silent Type"
msgstr "Kiểu Người Mạnh Mẽ, Trầm Lặng"

msgid "Finish <i>The Feast of Hemlock Vale</i> campaign without voluntarily triggering any codex entries."
msgstr "Hoàn thành campaign <i>The Feast of Hemlock Vale</i> mà không chủ động kích hoạt bất kỳ mục codex nào."

msgid "Colour Outside the Lines"
msgstr "Tô Màu Ngoài Đường Kẻ"

msgid "Skip both <i>The Twisted Hollow</i> and <i>The Longest Night</i> during a single playthrough."
msgstr "Bỏ qua cả <i>The Twisted Hollow</i> và <i>The Longest Night</i> trong một lần chơi."

msgid "Life of the Party"
msgstr "Tâm Điểm Bữa Tiệc"

msgid "Complete <i>The Feast of Hemlock Vale</i> campaign with each resident at Relationship Level 2 or higher."
msgstr "Hoàn thành campaign <i>The Feast of Hemlock Vale</i> với mỗi cư dân đạt Relationship Level 2 trở lên."

msgid "Dancing Queen"
msgstr "Nữ Hoàng Khiêu Vũ"

msgid "<i>Share a dance</i> with 4 different residents during <i>The Second Evening</i> prelude."
msgstr "<i>Chia sẻ một điệu nhảy</i> với 4 cư dân khác nhau trong prelude <i>The Second Evening</i>."

msgid "Audrey III"
msgstr "Audrey III"

msgid "Complete a scenario engaged with a Poisonblossom having 10 or more overgrowth on it."
msgstr "Hoàn thành một scenario trong khi đang giao chiến với một Poisonblossom có từ 10 overgrowth trở lên."

msgid "Hold on to your Potatoes!"
msgstr "Giữ Chặt Khoai Tây Nào!"

msgid "Complete <i>Written in Rock</i> with both a resident and the Prismatic Shard asset under your control."
msgstr "Hoàn thành <i>Written in Rock</i> với cả một cư dân và asset Prismatic Shard dưới quyền kiểm soát của bạn."

msgid "Dream Home Breakover"
msgstr "Dream Home Breakover"

msgid "Complete <i>Hemlock House</i> with 10 locations in the victory display."
msgstr "Hoàn thành <i>Hemlock House</i> với 10 địa điểm trong victory display."

msgid "Settling the Score"
msgstr "Thanh Toán Nợ Nần"

msgid "Defeat the Thing in the Depths in <i>The Thing in the Depths</i>."
msgstr "Đánh bại Thing in the Depths trong <i>The Thing in the Depths</i>."

msgid "“Here, Crabby Crabby!”"
msgstr "“Lại Đây Nào, Bé Cua!”"

msgid "Make the Limulus Hybrid flip at least 8 times during <i>The Lost Sister</i>."
msgstr "Khiến Limulus Hybrid lật ít nhất 8 lần trong <i>The Lost Sister</i>."

msgid "A Different Kind of Sting Ops"
msgstr "Một Kiểu Chiến Dịch Mật Phục Khác"

msgid "Complete <i>The Silent Heath</i> without spawning the Brood Queen."
msgstr "Hoàn thành <i>The Silent Heath</i> mà không spawn Brood Queen."

msgid "Wait, There’s No Shrouded Shrine?"
msgstr "Khoan đã, không có Shrouded Shrine sao?"

msgid "Survive <i>The Twisted Hollow</i> in Standalone Mode until you reach at least Darkness Level 10."
msgstr "Sống sót qua <i>The Twisted Hollow</i> trong chế độ Standalone cho đến khi bạn đạt ít nhất Darkness Level 10."

msgid "Bear Necessities"
msgstr "Nhu Cầu Thiết Yếu Của Gấu"

msgid "Defeat the Ursine Hybrid in <i>The Longest Night</i> using only scenario card effects."
msgstr "Đánh bại Ursine Hybrid trong <i>The Longest Night</i> chỉ bằng các hiệu ứng của thẻ scenario."

msgid "Let’s Do the Time Warp!"
msgstr "Hãy Cùng Bẻ Cong Thời Gian!"

msgid "Complete the Lambs to the Slaughter Resolution in <b>Prelude: The Final Evening</b>."
msgstr "Hoàn thành Resolution Lambs to the Slaughter trong <b>Prelude: The Final Evening</b>."

msgid "Oblivion Shmoblivion"
msgstr "Oblivion Shmoblivion"

msgid "Win the <i>Fate of the Vale</i> with each Cosmic Emissary enemy in the victory display."
msgstr "Chiến thắng <i>Fate of the Vale</i> với mọi kẻ địch Cosmic Emissary trong victory display."

msgid "High Dive"
msgstr "Cú Nhảy Từ Trên Cao"

msgid "Sacrifice yourself for the Vale in <i>Fate of the Vale</i>."
msgstr "Hy sinh bản thân vì Vale trong <i>Fate of the Vale</i>."

msgid "Best Friends Forever!"
msgstr "Mãi Mãi Là Bạn Thân!"

msgid "Reach Relationship Level 6 with the following residents:"
msgstr "Đạt Relationship Level 6 với các cư dân sau:"

msgid "Know Your Place"
msgstr "Biết Thân Biết Phận"

msgid "Win <i>The Feast of Hemlock Vale</i> campaign with Mother Rachel at Relationship Level 3."
msgstr "Chiến thắng campaign <i>The Feast of Hemlock Vale</i> với Mother Rachel đạt Relationship Level 3."

msgid "Heart of Steel"
msgstr "Trái Tim Thép"

msgid "Win <i>The Feast of Hemlock Vale</i> campaign with Judith Park at Relationship Level 7."
msgstr "Chiến thắng campaign <i>The Feast of Hemlock Vale</i> với Judith Park đạt Relationship Level 7."

msgid "Holding Out for a Himbo"
msgstr "Chờ Đợi Một Himbo"

msgid "Win <i>The Feast of Hemlock Vale</i> campaign with Theo Peters at Relationship Level 7."
msgstr "Chiến thắng campaign <i>The Feast of Hemlock Vale</i> với Theo Peters đạt Relationship Level 7."

msgid "Captivating Scream"
msgstr "Tiếng Hét Quyến Rũ"

msgid "Win <i>The Feast of Hemlock Vale</i> campaign as Patrice Hathaway."
msgstr "Chiến thắng campaign <i>The Feast of Hemlock Vale</i> trong vai Patrice Hathaway."

msgid "Line in the Sand"
msgstr "Lằn Ranh Trên Cát"

msgid "Win <i>The Feast of Hemlock Vale</i> campaign with at least three Ultimatums active."
msgstr "Chiến thắng chiến dịch <i>The Feast of Hemlock Vale</i> với ít nhất ba Ultimatum đang kích hoạt."

msgid "Hemlock Expertise"
msgstr "Chuyên Môn Hemlock"

msgid "Win <i>The Feast of Hemlock Vale</i> campaign on Expert difficulty"
msgstr "Chiến thắng chiến dịch <i>The Feast of Hemlock Vale</i> ở độ khó Expert"
