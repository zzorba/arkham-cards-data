msgstr "Vé Phạt Quá Tốc Độ"

msgid "Reach Falcon Point Approach without voluntarily stopping any vehicles, getting out of any vehicles, or entering a copy of Long Way Around in <i>Horror in High Gear</i>."
msgstr "Đến Falcon Point Approach mà không tự nguyện dừng bất kỳ phương tiện nào, ra khỏi bất kỳ phương tiện nào, hoặc đi vào một bản sao của Long Way Around trong <i>Horror in High Gear</i>."

msgid "You’re Locked In Here With Me"
msgstr "Các người bị nhốt ở đây cùng ta"

msgid "Complete <i>A Light in the Fog</i> without any investigators getting captured."
msgstr "Hoàn thành <i>A Light in the Fog</i> mà không có điều tra viên nào bị bắt."

msgid "Fish Out of Water"
msgstr "Cá mắc cạn"

msgid "Complete <i>Into the Maelstrom</i> with each investigator still wearing their Diving Suits."
msgstr "Hoàn thành <i>Into the Maelstrom</i> trong khi mỗi điều tra viên vẫn đang mặc Diving Suits của mình."

msgid "Don’t Wake Daddy"
msgstr "Đừng đánh thức bố"

msgid "Complete both <i>The Lair of Dagon</i> and <i>Into the Maelstrom</i> without waking Dagon or Hydra."
msgstr "Hoàn thành cả <i>The Lair of Dagon</i> và <i>Into the Maelstrom</i> mà không đánh thức Dagon hoặc Hydra."

msgid "Gone Fishing"
msgstr "Đi Câu Cá"

msgid "Defeat 20 [[Deep One]] enemies. Keep track with tally marks in your Campaign Log."
msgstr "Tiêu diệt 20 kẻ địch [[Deep One]]. Theo dõi bằng các dấu gạch đếm trong Nhật ký Chiến dịch của bạn."

msgid "Full Build"
msgstr "Trang Bị Đầy Đủ"

msgid "Equip the Waveworn Idol, Awakened Mantle and Headdress of Y’ha-nthlei at the same time."
msgstr "Trang bị Waveworn Idol, Awakened Mantle và Headdress of Y’ha-nthlei cùng một lúc."

msgid "“You Wake Up In A Room...”"
msgstr "“Bạn Tỉnh Dậy Trong Một Căn Phòng...”"

msgid "Recover each of the following memories throughout <i>The Innsmouth Conspiracy</i> campaign:"
msgstr "Khôi phục từng ký ức sau đây trong suốt chiến dịch <i>The Innsmouth Conspiracy</i>:"

msgid "A meeting with Thomas Dawson."
msgstr "Một cuộc gặp gỡ với Thomas Dawson."

msgid "A battle with a horrifying devil."
msgstr "Một trận chiến với một con ác quỷ kinh hoàng."

msgid "A decision to stick together."
msgstr "Một quyết định gắn bó cùng nhau."

msgid "An encounter with a secret cult."
msgstr "Một cuộc chạm trán với một giáo phái bí mật."

msgid "A deal with Joe Sargent."
msgstr "Một thỏa thuận với Joe Sargent."

msgid "A followed lead."
msgstr "Một manh mối được lần theo."

msgid "An intervention."
msgstr "Một sự can thiệp."

msgid "A jailbreak."
msgstr "Một cuộc vượt ngục."

msgid "Discovery of a strange idol."
msgstr "Phát hiện ra một bức tượng thần kỳ lạ."

msgid "Discovery of an unholy mantle."
msgstr "Phát hiện ra một chiếc áo choàng tà ác."

msgid "Discovery of a mystical relic."
msgstr "Phát hiện ra một di vật huyền bí."

msgid "A conversation with Mr. Moore."
msgstr "Một cuộc trò chuyện với ông Moore."

msgid "The lifecycle of a “Deep One.”"
msgstr "Vòng đời của một “Deep One.”"

msgid "A stinging betrayal."
msgstr "Một sự phản bội cay đắng."

msgid "The horrible truth."
msgstr "Sự thật kinh hoàng."

msgid "Bigger Fish to Fry"
msgstr "Có việc lớn hơn phải làm"

msgid "Complete <i>The Innsmouth Conspiracy</i> campaign without defeating a single [[Deep One]] enemy."
msgstr "Hoàn thành chiến dịch <i>The Innsmouth Conspiracy</i> mà không đánh bại bất kỳ kẻ địch [[Deep One]] nào."

msgid "Win <i>The Innsmouth Conspiracy</i> campaign with at least three Ultimatums active."
msgstr "Chiến thắng chiến dịch <i>The Innsmouth Conspiracy</i> với ít nhất ba Ultimatum đang kích hoạt."

msgid "Innsmouth Expertise"
msgstr "Sự am hiểu Innsmouth"

msgid "Win <i>The Innsmouth Conspiracy</i> campaign on Expert difficulty."
msgstr "Chiến thắng chiến dịch <i>The Innsmouth Conspiracy</i> ở độ khó Expert."
