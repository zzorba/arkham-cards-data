msgstr "Hồ sơ #44–O"

msgid ""
"<typewriter>Asset Name: Irawan, Dewi</typewriter>\n"
"<typewriter>Area of Operation: Southern Hemisphere</typewriter>"
msgstr ""
"<typewriter>Tên Đặc tình: Irawan, Dewi</typewriter>\r\n"
"<typewriter>Khu vực Hoạt động: Nam Bán cầu</typewriter>"

msgid ""
"<typewriter>Profile: Prominent zoologist has published several surveys "
"regarding disappearing wildlife. Zoologist claims entire species and the "
"memory of their existence are being erased. Possible █​█​█​█​█ "
"disturbance.</typewriter>"
msgstr ""
"<typewriter>Hồ sơ: Nhà động vật học nổi tiếng đã công bố một số khảo sát về "
"sự biến mất của động vật hoang dã. Nhà động vật học này tuyên bố rằng toàn "
"bộ các loài và ký ức về sự tồn tại của chúng đang bị xóa sổ. Có khả năng là "
"do xáo trộn █​█​█​█​█.</typewriter>"

